      {
        "id": "b08-c01-q01",
        "type": "quiz",
        "title": "King Activity Check 1",
        "question_md": "What should you do first in a position about **king activity**?",
        "options": [
          {
            "id": "a",
            "label": "Name the key signal before choosing a move.",
            "isCorrect": true
          },
          {
            "id": "b",
            "label": "Move instantly because the first idea is usually enough.",
            "isCorrect": false
          },
          {
            "id": "c",
            "label": "Ignore the diagram and choose by piece value only.",
            "isCorrect": false
