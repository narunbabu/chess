  "learningObjectives": [
    "Recognize the visual signal for king activity.",
    "Choose a move or plan that fits king activity.",
    "Avoid the common beginner error connected with king activity.",
    "Pass a checkpoint without relying on guesswork."
  ],
  "sections": [
    {
      "id": "goal-and-pattern",
      "title": "Goal And Pattern",
      "blocks": [
        {
          "id": "b08-c01-p01",
          "type": "prose",
          "body_md": "King Activity is not a memory trick. It is a way to organize the position. First name the signal, then compare candidate moves, then choose the move that improves your position without creating a new weakness."
        },
        {
