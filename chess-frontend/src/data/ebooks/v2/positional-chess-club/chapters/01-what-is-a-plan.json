  "chapterId": "01-what-is-a-plan",
  "title": "What Is A Plan",
  "subtitle": "What Is A Plan converted into a repeatable Chess99 training habit.",
  "eloRange": "1500-1800",
  "requiredTier": "silver",
  "estimatedMinutes": 28,
  "learningObjectives": [
    "Recognize the visual signal for what is a plan.",
    "Choose a move or plan that fits what is a plan.",
    "Avoid the common beginner error connected with what is a plan.",
    "Pass a checkpoint without relying on guesswork."
  ],
  "sections": [
    {
      "id": "goal-and-pattern",
      "title": "Goal And Pattern",
      "blocks": [
        {
          "id": "b07-c01-p01",
          "type": "prose",
          "body_md": "What Is A Plan is not a memory trick. It is a way to organize the position. First name the signal, then compare candidate moves, then choose the move that improves your position without creating a new weakness."
        },
        {
          "id": "b07-c01-d01",
