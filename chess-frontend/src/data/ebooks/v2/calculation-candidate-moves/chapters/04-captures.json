    "summary_md": "Pass this checkpoint only after you can explain captures without looking at the answer.",
    "blocks": [
      {
        "id": "b05-c04-q01",
        "type": "quiz",
        "title": "Captures Check 1",
        "question_md": "What should you do first in a position about **captures**?",
        "options": [
          {
            "id": "a",
            "label": "Name the key signal before choosing a move.",
            "isCorrect": true
          },
          {
            "id": "b",
            "label": "Move instantly because the first idea is usually enough.",
            "isCorrect": false
          },
          {
            "id": "c",
            "label": "Ignore the diagram and choose by piece value only.",
            "isCorrect": false
          }
        ]
      },
