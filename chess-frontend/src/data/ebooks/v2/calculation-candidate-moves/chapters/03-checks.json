  "checkpoint": {
    "id": "b05-c03-checkpoint",
    "title": "Chapter Checkpoint",
    "summary_md": "Pass this checkpoint only after you can explain checks without looking at the answer.",
    "blocks": [
      {
        "id": "b05-c03-q01",
        "type": "quiz",
        "title": "Checks Check 1",
        "question_md": "What should you do first in a position about **checks**?",
        "options": [
          {
            "id": "a",
            "label": "Name the key signal before choosing a move.",
            "isCorrect": true
          },
          {
            "id": "b",
            "label": "Move instantly because the first idea is usually enough.",
            "isCorrect": false
          },
          {
            "id": "c",
            "label": "Ignore the diagram and choose by piece value only.",
            "isCorrect": false
          }
        ]
      },
