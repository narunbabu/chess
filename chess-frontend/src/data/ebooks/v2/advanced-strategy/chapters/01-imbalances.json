  "sections": [
    {
      "id": "goal-and-pattern",
      "title": "Goal And Pattern",
      "blocks": [
        {
          "id": "b09-c01-p01",
          "type": "prose",
          "body_md": "Imbalances is not a memory trick. It is a way to organize the position. First name the signal, then compare candidate moves, then choose the move that improves your position without creating a new weakness."
        },
        {
          "id": "b09-c01-d01",
