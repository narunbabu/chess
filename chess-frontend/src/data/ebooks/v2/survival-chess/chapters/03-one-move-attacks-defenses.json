  "checkpoint": {
    "id": "b02-c03-checkpoint",
    "title": "Chapter Checkpoint",
    "summary_md": "Answer without guessing. The goal is a repeatable survival habit, not a lucky move.",
    "blocks": [
      {
        "id": "b02-c03-q01",
        "type": "quiz",
        "title": "A simple defense can be:",
        "question_md": "A simple defense can be:",
        "options": [
          {
            "id": "a",
            "label": "Move the attacked piece",
            "isCorrect": true
          },
          {
            "id": "b",
            "label": "Pretend there is no threat",
            "isCorrect": false
          },
          {
            "id": "c",
            "label": "Always move the queen",
            "isCorrect": false
          }
        ]
      },
      {
        "id": "b02-c03-q02",
