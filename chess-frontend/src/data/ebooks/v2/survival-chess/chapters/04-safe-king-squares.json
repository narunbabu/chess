  "checkpoint": {
    "id": "b02-c04-checkpoint",
    "title": "Chapter Checkpoint",
    "summary_md": "Answer without guessing. The goal is a repeatable survival habit, not a lucky move.",
    "blocks": [
      {
        "id": "b02-c04-q01",
        "type": "quiz",
        "title": "When in check, you may:",
        "question_md": "When in check, you may:",
        "options": [
          {
            "id": "a",
            "label": "Ignore it",
            "isCorrect": false
          },
          {
            "id": "b",
            "label": "Move, block, or capture the checker",
            "isCorrect": true
          },
          {
            "id": "c",
            "label": "Only move a pawn",
            "isCorrect": false
          }
        ]
      },
      {
        "id": "b02-c04-q02",
        "type": "quiz",
        "title": "A safe king square must be:",
