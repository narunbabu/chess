          {
            "id": "a",
            "label": "Not controlled by enemy pieces",
            "isCorrect": true
          },
          {
            "id": "b",
            "label": "On the same line as a rook check",
            "isCorrect": false
          },
          {
            "id": "c",
            "label": "Chosen quickly",
