  "chapterId": "09-blunder-check",
  "title": "Blunder-Check Before Every Move",
  "subtitle": "Pause once before the move leaves your hand.",
  "eloRange": "300-700",
  "requiredTier": "free",
  "estimatedMinutes": 24,
  "learningObjectives": [
    "Ask what your move leaves behind.",
    "Check whether your moved piece becomes loose.",
    "Notice immediate checks and captures against you."
  ],
