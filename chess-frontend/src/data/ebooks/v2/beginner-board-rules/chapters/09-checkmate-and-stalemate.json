{
  "schemaVersion": "2.0.0",
  "bookId": "beginner-board-rules",
  "chapterId": "09-checkmate-and-stalemate",
  "title": "Checkmate And Stalemate",
  "subtitle": "Winning requires mate, not just trapping the king.",
  "eloRange": "0-300",
  "requiredTier": "free",
  "estimatedMinutes": 30,
  "learningObjectives": [
    "Define checkmate as check with no legal escape.",
    "Recognize stalemate as no legal move but no check.",
    "Avoid stalemating a winning position.",
    "Deliver a simple queen-assisted mate."
  ],
  "sections": [
    {
      "id": "mate-meaning",
      "title": "Check Plus No Escape",
      "blocks": [
        {
          "id": "b01-c09-p01",
          "type": "prose",
          "body_md": "Checkmate means the king is in check and there is no legal escape. If the king is not in check, the position is not checkmate."
        },
        {
          "id": "b01-c09-d01",
          "type": "board_diagram",
          "title": "Queen-supported checkmate",
          "fen": "7k/6Q1/6K1/8/8/8/8/8 b - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "g7",
              "to": "h8",
              "colorRole": "check"
            }
          ],
          "highlights": [
            {
              "square": "h8",
              "colorRole": "check"
            },
            {
              "square": "g7",
              "colorRole": "best"
            },
            {
              "square": "g6",
              "colorRole": "safe"
            }
          ],
          "caption_md": "The queen checks h8, and the king on g6 supports the queen. Black has no escape.",
          "assertions": [
            {
              "type": "side_to_move",
              "value": "black"
            },
            {
              "type": "piece_on",
              "square": "h8",
              "piece": "black_king"
            },
            {
              "type": "piece_on",
              "square": "g7",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "g6",
              "piece": "white_king"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c09-d01-queen-supported-mate.png",
            "hash": "21430e4d20a7b424bad8a538c63b2bfa43fc97856dab24ff5f550bda220cbefb"
          }
        },
        {
          "id": "b01-c09-d02",
          "type": "board_diagram",
          "title": "Check but not mate",
          "fen": "7k/6Q1/8/8/8/8/8/6K1 b - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "g7",
              "to": "h8",
              "colorRole": "check"
            },
            {
              "from": "h8",
              "to": "g7",
              "colorRole": "capture"
            }
          ],
          "highlights": [
            {
              "square": "h8",
              "colorRole": "check"
            },
            {
              "square": "g7",
              "colorRole": "capture"
            }
          ],
          "caption_md": "This is check, but the queen is not protected. Black can capture it.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "h8",
              "piece": "black_king"
            },
            {
              "type": "piece_on",
              "square": "g7",
              "piece": "white_queen"
            },
            {
              "type": "legal_move",
              "move": "h8g7"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c09-d02-check-not-mate.png",
            "hash": "5c8b9324e67c3cd10445a0f43087a57a0a190c72a96392d3134032dcf982265b"
          }
        }
      ]
    },
    {
      "id": "stalemate",
      "title": "Stalemate Is Not A Win",
      "blocks": [
        {
          "id": "b01-c09-p02",
          "type": "prose",
          "body_md": "Stalemate happens when the player to move is not in check but has no legal move. Stalemate is a draw. Beginners lose many winning positions by forgetting this difference."
        },
        {
          "id": "b01-c09-d03",
          "type": "board_diagram",
          "title": "Stalemate pattern",
          "fen": "7k/5Q2/6K1/8/8/8/8/8 b - - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "h8",
              "colorRole": "safe"
            },
            {
              "square": "g8",
              "colorRole": "wrong"
            },
            {
              "square": "h7",
              "colorRole": "wrong"
            }
          ],
          "caption_md": "Black is not in check, but every black king move is controlled. This is stalemate, not checkmate.",
          "assertions": [
            {
              "type": "side_to_move",
              "value": "black"
            },
            {
              "type": "piece_on",
              "square": "h8",
              "piece": "black_king"
            },
            {
              "type": "piece_on",
              "square": "f7",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "g6",
              "piece": "white_king"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c09-d03-stalemate-pattern.png",
            "hash": "db56ce6b07951cd5a11b7b07cdc16827efb239f76095c4b78ded856e6ceb7997"
          }
        },
        {
          "id": "b01-c09-d04",
          "type": "board_diagram",
          "title": "The missing check",
          "fen": "7k/5Q2/6K1/8/8/8/8/8 b - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "f7",
              "to": "h7",
              "colorRole": "target"
            },
            {
              "from": "f7",
              "to": "g8",
              "colorRole": "target"
            }
          ],
          "highlights": [
            {
              "square": "h8",
              "colorRole": "safe"
            }
          ],
          "caption_md": "The queen controls escape squares, but she does not attack h8. No check means no checkmate.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "h8",
              "piece": "black_king"
            },
            {
              "type": "piece_on",
              "square": "f7",
              "piece": "white_queen"
            },
            {
              "type": "arrow_exists",
              "from": "f7",
              "to": "g8"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c09-d04-stalemate-missing-check.png",
            "hash": "cffe0aa3737e0dc769ee863a6220ee375f8f744fb839cb293e88684cbaa0173e"
          }
        },
        {
          "id": "b01-c09-d05",
          "type": "board_diagram",
          "title": "Mate move available",
          "fen": "7k/8/6K1/8/8/8/8/Q7 w - - 0 1",
