  ],
  "checkpoint": {
    "id": "b01-c09-checkpoint",
    "type": "checkpoint",
    "title": "Chapter Checkpoint",
    "requiredScore": 3,
    "summary_md": "Pass this chapter when you can explain the difference between checkmate and stalemate.",
    "blocks": [
      {
        "id": "b01-c09-q01",
        "type": "quiz",
        "title": "What is checkmate?",
        "question_md": "Checkmate means:",
        "options": [
          {
            "id": "a",
            "label": "The king is in check with no legal escape",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "The king has no legal move but is not checked",
            "isCorrect": false,
            "feedback": "That is stalemate."
          },
          {
            "id": "c",
            "label": "The queen was captured",
            "isCorrect": false,
            "feedback": "Mate is about the king."
          }
        ]
      },
      {
        "id": "b01-c09-q02",
        "type": "quiz",
        "title": "What is stalemate?",
        "question_md": "Stalemate means:",
        "options": [
          {
            "id": "a",
            "label": "No legal move and no check",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Check with no escape",
            "isCorrect": false,
            "feedback": "That is checkmate."
          },
          {
            "id": "c",
            "label": "Both players have queens",
            "isCorrect": false,
            "feedback": "Material does not define stalemate."
          }
        ]
      },
      {
        "id": "b01-c09-q03",
        "type": "quiz",
        "title": "Is stalemate a win?",
        "question_md": "Stalemate is:",
        "options": [
          {
            "id": "a",
            "label": "A draw",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "A win for the player with more pieces",
            "isCorrect": false,
            "feedback": "Stalemate is a draw."
          },
          {
            "id": "c",
            "label": "A checkmate",
            "isCorrect": false,
            "feedback": "The king is not in check."
          }
        ]
      }
    ]
  },
