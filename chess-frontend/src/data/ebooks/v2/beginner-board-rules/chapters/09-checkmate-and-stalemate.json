    },
    {
      "id": "mate-mistake",
      "title": "Common Mistake",
      "blocks": [
        {
          "id": "b01-c09-m01",
          "type": "mistake_refutation",
          "title": "Common mistake: stalemate instead of mate",
          "fen": "7k/5Q2/6K1/8/8/8/8/8 b - - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "h8",
              "colorRole": "safe"
            },
            {
              "square": "g8",
              "colorRole": "wrong"
            },
            {
              "square": "h7",
              "colorRole": "wrong"
            }
          ],
          "body_md": "This looks winning because the king is trapped, but the black king is not in check. Trapped without check is stalemate, so the game is drawn.",
          "caption_md": "No check on h8 means this is stalemate, not mate.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "h8",
              "piece": "black_king"
            },
            {
              "type": "piece_on",
              "square": "f7",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "g6",
              "piece": "white_king"
            }
          ],
          "exports": {
