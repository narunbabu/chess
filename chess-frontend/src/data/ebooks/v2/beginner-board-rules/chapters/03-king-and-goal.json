          }
        },
        {
          "id": "b01-c03-d02",
          "type": "board_diagram",
          "title": "Kings cannot touch",
          "fen": "8/8/8/8/4K3/8/4k3/8 w - - 0 1",
          "orientation": "white",
          "highlights": [
