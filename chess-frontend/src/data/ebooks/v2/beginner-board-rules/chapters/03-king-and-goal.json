            {
              "square": "d3",
              "colorRole": "wrong"
            },
            {
              "square": "f3",
              "colorRole": "wrong"
            }
          ],
          "caption_md": "The kings control the squares beside them. White may not move next to the black king.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "e4",
              "piece": "white_king"
            },
            {
              "type": "piece_on",
              "square": "e2",
              "piece": "black_king"
            },
            {
              "type": "highlight_exists",
              "square": "e3"
            }
          ],
          "exports": {
