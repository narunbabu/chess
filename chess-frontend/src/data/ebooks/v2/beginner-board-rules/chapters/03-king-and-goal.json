{
  "schemaVersion": "2.0.0",
  "bookId": "beginner-board-rules",
  "chapterId": "03-king-and-goal",
  "title": "The King And The Goal",
  "subtitle": "The king moves slowly, but the whole game turns around him.",
  "eloRange": "0-300",
  "requiredTier": "free",
  "estimatedMinutes": 24,
  "learningObjectives": [
    "Move the king one square in any direction.",
    "Know that kings may never stand next to each other.",
    "Understand that the king may not move into danger.",
    "Explain why the king is never traded or captured."
  ],
  "sections": [
    {
      "id": "king-basics",
      "title": "The King Is The Game",
      "blocks": [
        {
          "id": "b01-c03-p01",
          "type": "prose",
          "body_md": "Every piece can be traded except the king. You do not win by taking the king off the board. You win by attacking the king so strongly that there is no legal escape. That final position is checkmate."
        },
        {
          "id": "b01-c03-d01",
          "type": "board_diagram",
          "title": "The king moves one square",
          "fen": "8/8/8/8/4K3/8/8/4k3 w - - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "d5",
              "colorRole": "safe"
            },
            {
              "square": "e5",
              "colorRole": "safe"
            },
            {
              "square": "f5",
              "colorRole": "safe"
            },
            {
              "square": "d4",
              "colorRole": "safe"
            },
            {
              "square": "f4",
              "colorRole": "safe"
            },
            {
              "square": "d3",
              "colorRole": "safe"
            },
            {
              "square": "e3",
              "colorRole": "safe"
            },
            {
              "square": "f3",
              "colorRole": "safe"
            }
          ],
          "caption_md": "From e4, the king can step to any adjacent highlighted square if that square is safe.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "e4",
