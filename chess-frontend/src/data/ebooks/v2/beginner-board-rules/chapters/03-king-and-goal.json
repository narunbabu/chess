  "checkpoint": {
    "id": "b01-c03-checkpoint",
    "type": "checkpoint",
    "title": "Chapter Checkpoint",
    "requiredScore": 3,
    "summary_md": "Pass this chapter when you can move the king one square, reject unsafe squares, and explain why kings may not touch.",
    "blocks": [
      {
        "id": "b01-c03-q01",
        "type": "quiz",
        "title": "How far does a king move?",
        "question_md": "A king normally moves:",
        "options": [
          {
            "id": "a",
            "label": "One square in any direction",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Any number of squares in a straight line",
            "isCorrect": false,
            "feedback": "That is how a rook or queen can move."
          },
          {
            "id": "c",
            "label": "Only forward",
            "isCorrect": false,
            "feedback": "Kings can move backward, sideways, and diagonally."
          }
        ]
      },
      {
        "id": "b01-c03-q02",
        "type": "quiz",
        "title": "Can kings stand next to each other?",
        "question_md": "Two kings may stand on adjacent squares:",
        "options": [
          {
            "id": "a",
            "label": "No",
            "isCorrect": true,
            "feedback": "Correct. Kings may not touch."
          },
          {
            "id": "b",
            "label": "Yes, if no other pieces are nearby",
            "isCorrect": false,
            "feedback": "Kings attack adjacent squares, so they cannot touch."
          },
          {
            "id": "c",
            "label": "Only in the endgame",
            "isCorrect": false,
            "feedback": "The rule never changes."
          }
        ]
      },
      {
        "id": "b01-c03-q03",
        "type": "quiz",
        "title": "What makes a king move illegal?",
        "question_md": "A one-square king move is illegal when:",
        "options": [
          {
            "id": "a",
            "label": "The landing square is attacked",
            "isCorrect": true,
            "feedback": "Correct. The king may not move into danger."
          },
          {
            "id": "b",
            "label": "The king moves diagonally",
            "isCorrect": false,
            "feedback": "Diagonal king moves are allowed if safe."
          },
          {
            "id": "c",
            "label": "The king captures a piece",
            "isCorrect": false,
            "feedback": "Kings can capture loose enemy pieces."
          }
        ]
      }
    ]
  },
