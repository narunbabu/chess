    {
      "id": "king-mistake",
      "title": "Common Mistake",
      "blocks": [
        {
          "id": "b01-c03-m01",
          "type": "mistake_refutation",
          "title": "Common mistake: walking into attack",
          "fen": "4r3/8/8/8/3K4/8/8/6k1 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "d4",
              "to": "e4",
              "colorRole": "wrong"
            },
            {
              "from": "e8",
              "to": "e4",
              "colorRole": "check"
            }
          ],
          "highlights": [
            {
              "square": "e4",
              "colorRole": "wrong"
            }
          ],
          "body_md": "The move from d4 to e4 looks like a legal one-square move, but e4 is controlled by the rook on e8. A king move must satisfy both rules: one square and safe.",
          "caption_md": "The red square is not safe. The rook already controls it.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "d4",
              "piece": "white_king"
            },
            {
              "type": "piece_on",
              "square": "e8",
              "piece": "black_rook"
            },
            {
              "type": "arrow_exists",
              "from": "e8",
              "to": "e4"
            }
          ],
          "exports": {
