          }
        }
      ]
    },
    {
      "id": "king-safety",
      "title": "Safe Squares Matter",
      "blocks": [
        {
          "id": "b01-c03-p02",
          "type": "prose",
          "body_md": "A king move has two questions. First, does the king move one square? Second, is the landing square safe? A one-square move is still illegal if the king walks into an attack."
        },
        {
          "id": "b01-c03-d03",
          "type": "board_diagram",
          "title": "The king can capture a loose piece",
          "fen": "8/8/8/3p4/4K3/8/8/4k3 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e4",
              "to": "d5",
              "colorRole": "capture"
            }
          ],
          "highlights": [
            {
              "square": "d5",
              "colorRole": "capture"
            }
          ],
          "caption_md": "If the pawn on d5 is not protected, the king may capture it by moving one square diagonally.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "e4",
              "piece": "white_king"
            },
            {
              "type": "piece_on",
              "square": "d5",
              "piece": "black_pawn"
            },
            {
              "type": "legal_move",
              "move": "e4d5"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c03-d03-king-captures-loose-pawn.png",
            "hash": "3abceca38b6647e45bb21af6bdd4997b8b7d9fa806ec82e5563421f395d2286d"
          }
        },
        {
          "id": "b01-c03-d04",
          "type": "board_diagram",
          "title": "A rook controls the e-file",
          "fen": "4r3/8/8/8/3K4/8/8/6k1 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e8",
              "to": "e4",
              "colorRole": "check"
            }
          ],
          "highlights": [
            {
              "square": "e4",
              "colorRole": "wrong"
            }
          ],
          "caption_md": "The black rook controls e4, so the white king on d4 may not step onto e4.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "d4",
              "piece": "white_king"
            },
            {
              "type": "piece_on",
              "square": "e8",
              "piece": "black_rook"
            },
            {
              "type": "arrow_exists",
              "from": "e8",
              "to": "e4"
            }
          ],
          "exports": {
