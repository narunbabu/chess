  "chapterId": "05-queen-power",
  "title": "The Queen And Long-Range Power",
  "subtitle": "The queen combines rook lines and bishop diagonals.",
  "eloRange": "0-300",
  "requiredTier": "free",
  "estimatedMinutes": 24,
  "learningObjectives": [
    "Move the queen along ranks, files, and diagonals.",
    "Recognize that the queen cannot jump.",
    "Use the queen to target weak squares.",
    "Avoid bringing the queen into easy attack too early."
  ],
  "sections": [
    {
      "id": "queen-lines",
      "title": "The Queen Combines Two Pieces",
      "blocks": [
        {
          "id": "b01-c05-p01",
          "type": "prose",
          "body_md": "The queen is the strongest attacking piece because she moves like a rook and a bishop together. She can use files, ranks, and diagonals, but she still cannot jump."
