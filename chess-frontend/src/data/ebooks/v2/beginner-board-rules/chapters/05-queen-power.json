        "title": "How does the queen move?",
        "question_md": "The queen moves like:",
        "options": [
          {
            "id": "a",
            "label": "A rook and bishop combined",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "A knight and pawn combined",
            "isCorrect": false,
            "feedback": "The queen does not jump like a knight."
          },
          {
            "id": "c",
            "label": "Only one square",
            "isCorrect": false,
            "feedback": "That is the king."
          }
        ]
      },
      {
        "id": "b01-c05-q02",
        "type": "quiz",
        "title": "Can a queen jump?",
        "question_md": "A queen can jump over pieces:",
        "options": [
          {
            "id": "a",
            "label": "No",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Yes, if she captures",
            "isCorrect": false,
            "feedback": "Captures still require a clear path."
          },
          {
            "id": "c",
            "label": "Only diagonally",
            "isCorrect": false,
            "feedback": "The queen never jumps."
          }
        ]
      },
      {
        "id": "b01-c05-q03",
        "type": "quiz",
        "title": "Why can early queen moves be risky?",
        "question_md": "Early queen moves can be risky because:",
        "options": [
          {
            "id": "a",
            "label": "The queen may get attacked and lose time",
