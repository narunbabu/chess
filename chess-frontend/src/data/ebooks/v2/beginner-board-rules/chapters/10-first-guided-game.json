  "chapterId": "10-first-guided-game",
  "title": "Your First Guided Game",
  "subtitle": "Use the rules together in one short game.",
  "eloRange": "0-300",
  "requiredTier": "free",
  "estimatedMinutes": 32,
  "learningObjectives": [
    "Play a legal opening sequence from the starting position.",
    "See how center control opens queen and bishop lines.",
    "Recognize a simple mate threat on f7.",
    "Complete a short guided game ending in checkmate."
  ],
  "sections": [
    {
      "id": "game-start",
      "title": "A Short Legal Game",
      "blocks": [
        {
          "id": "b01-c10-p01",
          "type": "prose",
          "body_md": "Now we connect the first rules into a real sequence. This short game is not a full opening course. Its purpose is to show how legal moves, piece lines, check, and checkmate fit together."
        },
        {
          "id": "b01-c10-d01",
          "type": "board_diagram",
          "title": "Start from the normal setup",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "e2",
              "colorRole": "best"
            },
            {
              "square": "e7",
              "colorRole": "target"
            }
          ],
          "caption_md": "The game begins from the correct starting position.",
          "assertions": [
            {
              "type": "side_to_move",
              "value": "white"
            },
            {
              "type": "piece_on",
              "square": "e2",
              "piece": "white_pawn"
            },
            {
              "type": "piece_on",
              "square": "e7",
              "piece": "black_pawn"
            }
          ],
          "exports": {
