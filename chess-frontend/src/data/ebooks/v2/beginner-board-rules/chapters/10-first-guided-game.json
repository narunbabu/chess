  "checkpoint": {
    "id": "b01-c10-checkpoint",
    "type": "checkpoint",
    "title": "Chapter Checkpoint",
    "requiredScore": 3,
    "summary_md": "Pass this chapter when you can replay the short legal game and explain why the final move is checkmate.",
    "blocks": [
      {
        "id": "b01-c10-q01",
        "type": "quiz",
        "title": "What did 1.e4 open?",
        "question_md": "The move 1.e4 helps open lines for:",
        "options": [
          {
            "id": "a",
            "label": "The queen and bishop",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Only the rook on a1",
            "isCorrect": false,
            "feedback": "The e-pawn mainly opens central lines."
          },
          {
            "id": "c",
            "label": "Only the king",
            "isCorrect": false,
            "feedback": "The king is not trying to run out early."
          }
        ]
      },
      {
        "id": "b01-c10-q02",
        "type": "quiz",
        "title": "Which square was targeted?",
        "question_md": "In the guided game, White attacked:",
