    {
      "id": "game-mistake",
      "title": "Common Mistake",
      "blocks": [
        {
          "id": "b01-c10-m01",
          "type": "mistake_refutation",
          "title": "Common mistake: moving without checking threats",
          "fen": "r1bqkbnr/pppp1ppp/2n5/4p2Q/2B1P3/8/PPPP1PPP/RNB1K1NR b KQkq - 3 3",
          "orientation": "white",
          "arrows": [
            {
              "from": "h5",
              "to": "f7",
              "colorRole": "threat"
            },
            {
              "from": "c4",
              "to": "f7",
              "colorRole": "threat"
            }
          ],
          "highlights": [
            {
              "square": "f7",
              "colorRole": "target"
            }
          ],
          "body_md": "Black must notice the threat on f7. A move that ignores both queen and bishop pressure can allow Qxf7 mate.",
          "caption_md": "Both attacking pieces point to f7. The threat should be checked before moving.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "h5",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "c4",
              "piece": "white_bishop"
            },
            {
              "type": "piece_on",
              "square": "f7",
              "piece": "black_pawn"
