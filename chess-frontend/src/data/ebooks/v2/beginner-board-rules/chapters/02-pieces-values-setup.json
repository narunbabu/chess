    {
      "id": "setup-rules",
      "title": "The Setup Rules That Prevent Mistakes",
      "blocks": [
        {
          "id": "b01-c02-p03",
          "type": "prose",
          "body_md": "The fastest setup check is the queen rule: queen on her own color. The White queen starts on the light square d1. The Black queen starts on the dark square d8.\n\nAfter the queen and king are correct, the bishops stand beside them, the knights stand beside the bishops, and the rooks go in the corners."
        },
        {
          "id": "b01-c02-d05",
          "type": "board_diagram",
          "title": "Queen on her own color",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "d1",
              "colorRole": "best"
            },
            {
              "square": "d8",
              "colorRole": "best"
            }
          ],
          "caption_md": "White queen on d1, Black queen on d8. Queen on her own color fixes the center of the back rank.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "d1",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "d8",
              "piece": "black_queen"
            },
            {
              "type": "highlight_exists",
              "square": "d1"
            },
            {
              "type": "highlight_exists",
              "square": "d8"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c02-d05-queen-color.png",
            "hash": "c3387818914dcfeb6f9d6347f01a41efb33267a7e89686be6099e3016be8e457"
          }
        },
        {
