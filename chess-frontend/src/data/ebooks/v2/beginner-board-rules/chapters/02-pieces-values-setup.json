          "id": "b01-c02-m01",
          "type": "mistake_refutation",
          "title": "Common mistake: swapping king and queen",
          "fen": "rnbkqbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBKQBNR w - - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "d1",
              "colorRole": "wrong"
            },
            {
              "square": "e1",
              "colorRole": "wrong"
            },
            {
              "square": "d8",
              "colorRole": "wrong"
            },
            {
              "square": "e8",
              "colorRole": "wrong"
            }
          ],
          "body_md": "This setup looks close, but both queens and kings are swapped. White's queen has been put on e1 instead of d1. Black's queen has been put on e8 instead of d8.\n\nFix it by returning each queen to her own color.",
          "caption_md": "The wrong setup places White queen on e1 and Black queen on e8. Both queens should be on the d-file.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "d1",
              "piece": "white_king"
            },
            {
              "type": "piece_on",
              "square": "e1",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "d8",
              "piece": "black_king"
            },
            {
              "type": "piece_on",
              "square": "e8",
              "piece": "black_queen"
            }
          ],
          "exports": {
