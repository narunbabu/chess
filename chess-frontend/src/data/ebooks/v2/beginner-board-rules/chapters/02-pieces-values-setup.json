    {
      "id": "identify-and-move",
      "title": "Identify A Piece, Then Move It",
      "blocks": [
        {
          "id": "b01-c02-p04",
          "type": "prose",
          "body_md": "When you know the setup, you can name a piece by its square. The piece on e2 at the start is White's e-pawn.\n\nIn the next board, move only that pawn one square forward to e3. The goal is not speed; the goal is matching the piece name, square name, and move."
        },
        {
          "id": "b01-c02-d07",
          "type": "board_diagram",
          "title": "Find White's e-pawn",
