    {
      "id": "piece-names-values",
      "title": "Piece Names And Simple Values",
      "blocks": [
        {
          "id": "b01-c02-p02",
          "type": "prose",
          "body_md": "The king is the most important piece because losing the king means losing the game. Do not give the king a point value.\n\nFor simple counting, use this first material scale: queen 9, rook 5, bishop 3, knight 3, pawn 1. These numbers are not the whole story, but they help you notice when a trade is obviously good or bad."
        },
        {
          "id": "b01-c02-d03",
          "type": "board_diagram",
          "title": "The royal pieces",
          "fen": "4k3/8/8/8/8/8/8/3QK3 w - - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "e1",
              "colorRole": "check"
            },
            {
              "square": "d1",
              "colorRole": "best"
            },
            {
              "square": "e8",
              "colorRole": "check"
            }
          ],
          "caption_md": "The kings are on e1 and e8 in a normal setup. White's queen begins on d1.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "e1",
              "piece": "white_king"
            },
            {
              "type": "piece_on",
              "square": "d1",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "e8",
