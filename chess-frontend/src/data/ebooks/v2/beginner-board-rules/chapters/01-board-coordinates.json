          }
        }
      ]
    },
    {
      "id": "files-ranks-coordinates",
      "title": "Files, Ranks, And Square Names",
      "blocks": [
        {
          "id": "b01-c01-p02",
          "type": "prose",
          "body_md": "The vertical columns are **files**. They are named a through h from White's left to White's right.\n\nThe horizontal rows are **ranks**. They are numbered 1 through 8 from White's side toward Black's side.\n\nA square name is file plus rank. The square **e4** means the e-file and the 4th rank."
        },
        {
          "id": "b01-c01-d03",
          "type": "board_diagram",
          "title": "The e-file",
          "fen": "8/8/8/8/8/8/8/8 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e1",
              "to": "e8",
              "colorRole": "candidate"
            }
          ],
          "highlights": [
            {
              "square": "e1",
              "colorRole": "safe"
            },
            {
              "square": "e2",
              "colorRole": "safe"
            },
            {
              "square": "e3",
              "colorRole": "safe"
            },
            {
              "square": "e4",
              "colorRole": "target"
            },
            {
              "square": "e5",
              "colorRole": "target"
            },
            {
              "square": "e6",
              "colorRole": "safe"
            },
            {
              "square": "e7",
              "colorRole": "safe"
            },
            {
              "square": "e8",
              "colorRole": "safe"
            }
          ],
          "caption_md": "Every square in this column starts with e: e1, e2, e3, and so on.",
          "assertions": [
            {
              "type": "highlight_exists",
              "square": "e4"
            },
            {
              "type": "arrow_exists",
              "from": "e1",
              "to": "e8"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c01-d03-e-file.png",
            "hash": "8a7bb6d9d9a3a84e341de222033515111791d9d32201475f81a291aed5a46abf"
          }
        },
        {
          "id": "b01-c01-d04",
          "type": "board_diagram",
          "title": "The 4th rank",
          "fen": "8/8/8/8/8/8/8/8 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "a4",
              "to": "h4",
              "colorRole": "capture"
            }
          ],
          "highlights": [
            {
              "square": "a4",
              "colorRole": "safe"
            },
            {
              "square": "b4",
              "colorRole": "safe"
            },
            {
              "square": "c4",
              "colorRole": "safe"
            },
            {
              "square": "d4",
              "colorRole": "target"
            },
            {
              "square": "e4",
              "colorRole": "target"
            },
            {
              "square": "f4",
              "colorRole": "safe"
            },
            {
              "square": "g4",
              "colorRole": "safe"
            },
            {
              "square": "h4",
              "colorRole": "safe"
            }
          ],
          "caption_md": "Every square in this row ends with 4: a4, b4, c4, d4, e4, f4, g4, h4.",
          "assertions": [
            {
              "type": "highlight_exists",
              "square": "d4"
            },
            {
              "type": "arrow_exists",
              "from": "a4",
              "to": "h4"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c01-d04-fourth-rank.png",
            "hash": "0b74c517314927bccd3bf342c4f53b60fd608ff0958d28591d2d780561c13fd2"
          }
        },
        {
          "id": "b01-c01-d05",
          "type": "board_diagram",
          "title": "A piece on e4",
          "fen": "8/8/8/8/4N3/8/8/8 w - - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "e4",
              "colorRole": "best"
            }
          ],
          "caption_md": "The knight is on e4: e-file, 4th rank. Say it aloud before moving on.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "e4",
              "piece": "white_knight"
            },
            {
              "type": "highlight_exists",
              "square": "e4"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c01-d05-knight-e4.png",
