    {
      "id": "first-move",
      "title": "A Move Has Two Squares",
      "blocks": [
        {
          "id": "b01-c01-p03",
          "type": "prose",
          "body_md": "A written move often starts with two coordinates: the square the piece leaves and the square it lands on.\n\nFor example, **e2e4** means: take the piece on e2 and move it to e4. In a normal starting position, that piece is White's king pawn."
        },
        {
          "id": "b01-c01-d06",
          "type": "board_diagram",
          "title": "Before 1.e4",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e2",
              "to": "e4",
              "colorRole": "best"
            }
          ],
          "highlights": [
            {
              "square": "e2",
              "colorRole": "lastMove"
            },
            {
              "square": "e4",
              "colorRole": "best"
            }
          ],
          "caption_md": "The arrow shows the pawn's first move: e2 to e4.",
          "assertions": [
            {
              "type": "side_to_move",
              "value": "white"
            },
            {
              "type": "piece_on",
              "square": "e2",
              "piece": "white_pawn"
            },
            {
              "type": "legal_move",
              "move": "e2e4"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c01-d06-before-e4.png",
            "hash": "cab16a7b8d27fb4b3f61ccfdd13a34adc4a7038d861a7844e4d9f9ced2de36ba"
          }
        },
        {
          "id": "b01-c01-g01",
          "type": "guided_move",
          "title": "Play e2 to e4",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "prompt_md": "Move the pawn from e2 to e4. Use the coordinates, not guesswork.",
          "acceptedMoves": [
            "e2e4"
          ],
          "successMessage": "Correct. You read a move as from-square to to-square.",
          "failureMessage": "Use the e-file pawn and land on e4.",
          "arrows": [
            {
              "from": "e2",
              "to": "e4",
              "colorRole": "best"
            }
          ],
          "highlights": [
            {
              "square": "e2",
              "colorRole": "lastMove"
            },
            {
              "square": "e4",
              "colorRole": "best"
            }
          ],
          "assertions": [
            {
              "type": "legal_move",
              "move": "e2e4"
            }
          ]
        },
        {
          "id": "b01-c01-a01",
          "type": "board_animation",
          "title": "The board after 1.e4",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "sequence": [
            {
              "move": "e2e4",
              "arrow": {
                "from": "e2",
                "to": "e4",
                "colorRole": "best"
              }
            }
          ],
          "speed": "slow",
          "caption_md": "After e2e4, the pawn leaves e2 and stands on e4. The move also opens lines for White's queen and bishop.",
          "assertions": [
            {
              "type": "legal_move",
              "move": "e2e4"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c01-a01-e4-animation.png",
            "hash": "246d262d03f9a9e61a2e06fec5ba00b4cd579bee166f6495298cc875b9831bad"
