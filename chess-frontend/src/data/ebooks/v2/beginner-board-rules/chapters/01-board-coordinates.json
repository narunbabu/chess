    },
    {
      "id": "common-mistake",
      "title": "Common Mistake: Trusting The Picture, Not The Coordinates",
      "blocks": [
        {
          "id": "b01-c01-m01",
          "type": "mistake_refutation",
          "title": "Wrong board orientation ruins every square name",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "highlights": [
            {
              "square": "h1",
              "colorRole": "best"
            },
            {
              "square": "d1",
              "colorRole": "target"
            },
            {
              "square": "d8",
              "colorRole": "target"
            }
          ],
          "body_md": "If the board is rotated incorrectly in real life, every coordinate becomes unreliable. The simple check is: **light square on the right** for White. Then queens start on their own color: White queen on d1, Black queen on d8.",
          "caption_md": "h1 is the orientation check. d1 and d8 show the queen-on-own-color rule.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "h1",
              "piece": "white_rook"
            },
            {
              "type": "piece_on",
              "square": "d1",
              "piece": "white_queen"
            },
            {
              "type": "piece_on",
              "square": "d8",
              "piece": "black_queen"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c01-m01-orientation.png",
            "hash": "eb94c09513cedf2553070d22aabf9e0d0bfb1af59c14190d3331c346148cb9b1"
          }
        },
        {
          "id": "b01-c01-q01",
          "type": "quiz",
          "title": "Checkpoint: name the square",
          "question_md": "A knight is placed on the e-file and the 4th rank. What square is it on?",
          "options": [
            {
              "id": "a",
              "label": "d4",
              "isCorrect": false,
              "feedback": "d4 is the d-file, 4th rank."
            },
            {
              "id": "b",
              "label": "e4",
              "isCorrect": true,
              "feedback": "Correct. File first, rank second."
            },
            {
              "id": "c",
              "label": "4e",
              "isCorrect": false,
              "feedback": "Chess coordinates use file first, then rank."
            }
          ],
          "successMessage": "Good. You can now read a basic coordinate."
        }
      ]
    }
  ],
  "checkpoint": {
    "id": "b01-c01-checkpoint",
    "type": "checkpoint",
    "title": "Chapter Checkpoint",
    "requiredScore": 3,
    "summary_md": "Pass this chapter when you can name h1, d4, e4, and play e2e4 without hints.",
    "blocks": [
      {
        "id": "b01-c01-q02",
        "type": "quiz",
        "title": "Which square is White's bottom-right corner?",
        "question_md": "With White at the bottom, the bottom-right corner is:",
        "options": [
          {
            "id": "a",
            "label": "a1",
            "isCorrect": false,
            "feedback": "a1 is White's bottom-left corner."
          },
          {
            "id": "b",
            "label": "h1",
            "isCorrect": true,
            "feedback": "Correct. h1 must be a light square."
          },
          {
            "id": "c",
            "label": "h8",
            "isCorrect": false,
            "feedback": "h8 is on Black's back rank."
          }
        ]
      },
      {
        "id": "b01-c01-q03",
        "type": "quiz",
        "title": "How do you read e2e4?",
        "question_md": "The move e2e4 means:",
        "options": [
          {
            "id": "a",
            "label": "Move from e2 to e4",
            "isCorrect": true,
            "feedback": "Correct. First square is the start, second square is the destination."
          },
          {
            "id": "b",
            "label": "Move from e4 to e2",
            "isCorrect": false,
            "feedback": "The order matters: e2 first, e4 second."
          },
          {
            "id": "c",
            "label": "Move any pawn two squares",
            "isCorrect": false,
            "feedback": "Coordinates name exact squares, not just a general idea."
          }
        ]
      }
    ]
  },
