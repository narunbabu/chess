          ],
          "highlights": [
            {
              "square": "d6",
              "colorRole": "wrong"
            },
            {
              "square": "f6",
              "colorRole": "best"
            }
          ],
          "body_md": "A bishop on d4 cannot move to d6. That is a straight-file move, and bishops only use diagonals.",
          "caption_md": "d4 to d6 is wrong. d4 to f6 is diagonal and legal if the path is clear.",
          "assertions": [
            {
              "type": "piece_on",
