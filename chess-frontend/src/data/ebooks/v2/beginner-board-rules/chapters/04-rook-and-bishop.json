  "checkpoint": {
    "id": "b01-c04-checkpoint",
    "type": "checkpoint",
    "title": "Chapter Checkpoint",
    "requiredScore": 3,
    "summary_md": "Pass this chapter when you can separate straight rook moves from diagonal bishop moves.",
    "blocks": [
      {
        "id": "b01-c04-q01",
        "type": "quiz",
        "title": "Which lines does a rook use?",
        "question_md": "A rook moves along:",
        "options": [
          {
            "id": "a",
            "label": "Files and ranks",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Only diagonals",
            "isCorrect": false,
            "feedback": "That is the bishop."
          },
          {
            "id": "c",
            "label": "Knight jumps",
            "isCorrect": false,
            "feedback": "Rooks do not jump."
          }
        ]
      },
      {
        "id": "b01-c04-q02",
        "type": "quiz",
        "title": "Can a bishop change color?",
        "question_md": "A bishop that starts on a dark square can later land on a light square:",
        "options": [
          {
            "id": "a",
            "label": "No",
            "isCorrect": true,
            "feedback": "Correct. Diagonals keep the same color."
          },
          {
            "id": "b",
            "label": "Yes, after a capture",
            "isCorrect": false,
            "feedback": "Captures still follow diagonal movement."
          },
          {
            "id": "c",
            "label": "Only near the edge",
            "isCorrect": false,
            "feedback": "The rule is the same everywhere."
          }
        ]
      },
      {
        "id": "b01-c04-q03",
        "type": "quiz",
        "title": "What blocks a rook?",
        "question_md": "A rook is blocked by:",
        "options": [
          {
            "id": "a",
            "label": "Any piece on its path",
            "isCorrect": true,
            "feedback": "Correct. Rooks cannot jump."
          },
          {
            "id": "b",
            "label": "Only enemy pieces",
            "isCorrect": false,
            "feedback": "Friendly pieces block too."
          },
          {
            "id": "c",
            "label": "Only the king",
            "isCorrect": false,
            "feedback": "Any piece blocks a rook line."
          }
        ]
      }
    ]
  },
