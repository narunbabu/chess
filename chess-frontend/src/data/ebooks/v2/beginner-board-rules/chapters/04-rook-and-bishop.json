  "chapterId": "04-rook-and-bishop",
  "title": "Rooks And Bishops",
  "subtitle": "Straight lines and diagonals are the first long-range patterns.",
  "eloRange": "0-300",
  "requiredTier": "free",
  "estimatedMinutes": 26,
  "learningObjectives": [
    "Move a rook along ranks and files.",
    "Move a bishop along diagonals.",
    "Notice when friendly pieces block long-range pieces.",
    "Explain why bishops stay on one color complex."
  ],
  "sections": [
    {
      "id": "rook-lines",
      "title": "Rooks Use Files And Ranks",
      "blocks": [
        {
          "id": "b01-c04-p01",
          "type": "prose",
          "body_md": "The rook is the straight-line piece. It moves up, down, left, or right as far as the path is clear. It cannot jump over pieces."
        },
        {
          "id": "b01-c04-d01",
          "type": "board_diagram",
