          "title": "Two-square first move",
          "fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e2",
              "to": "e4",
