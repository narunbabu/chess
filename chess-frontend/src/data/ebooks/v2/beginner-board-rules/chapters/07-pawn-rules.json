    "blocks": [
      {
        "id": "b01-c07-q01",
        "type": "quiz",
        "title": "How does a white pawn move?",
        "question_md": "A white pawn normally moves:",
        "options": [
          {
            "id": "a",
            "label": "Toward higher ranks",
            "isCorrect": true,
            "feedback": "Correct. White pawns move toward rank 8."
          },
          {
            "id": "b",
            "label": "Backward toward rank 1",
            "isCorrect": false,
            "feedback": "That is backward for White."
          },
          {
            "id": "c",
            "label": "Sideways",
            "isCorrect": false,
            "feedback": "Pawns do not move sideways."
          }
        ]
      },
      {
        "id": "b01-c07-q02",
        "type": "quiz",
        "title": "How does a pawn capture?",
        "question_md": "A pawn captures:",
        "options": [
          {
            "id": "a",
            "label": "One square diagonally forward",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Straight forward",
            "isCorrect": false,
            "feedback": "Pawns move forward but capture diagonally."
          },
          {
            "id": "c",
            "label": "Like a knight",
            "isCorrect": false,
            "feedback": "Pawns do not jump."
          }
        ]
      },
      {
        "id": "b01-c07-q03",
        "type": "quiz",
        "title": "What happens on the last rank?",
        "question_md": "A pawn that reaches the last rank:",
        "options": [
          {
            "id": "a",
            "label": "Promotes",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Disappears",
            "isCorrect": false,
            "feedback": "It becomes another piece."
          },
          {
            "id": "c",
            "label": "Must become a king",
            "isCorrect": false,
            "feedback": "A side can never have two kings."
          }
        ]
      }
    ]
  },
