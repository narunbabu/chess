          ],
          "exports": {
            "png": "assets/diagrams/b01-c07-d02-pawn-two-step-e4.png",
            "hash": "cab16a7b8d27fb4b3f61ccfdd13a34adc4a7038d861a7844e4d9f9ced2de36ba"
          }
        }
      ]
    },
    {
      "id": "pawn-captures",
      "title": "Captures And Promotion",
      "blocks": [
        {
          "id": "b01-c07-p02",
          "type": "prose",
          "body_md": "A pawn does not capture straight ahead. It captures one square diagonally forward. If a pawn reaches the last rank, it promotes, usually to a queen."
        },
        {
          "id": "b01-c07-d03",
          "type": "board_diagram",
          "title": "Pawn captures diagonally",
          "fen": "4k3/8/8/8/3p1p2/4P3/8/4K3 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e3",
              "to": "d4",
              "colorRole": "capture"
            },
            {
              "from": "e3",
              "to": "f4",
              "colorRole": "capture"
            }
          ],
          "highlights": [
            {
              "square": "d4",
              "colorRole": "target"
            },
            {
              "square": "f4",
              "colorRole": "target"
            }
          ],
          "caption_md": "The pawn on e3 can capture the enemy pawns on d4 or f4.",
          "assertions": [
            {
              "type": "piece_on",
              "square": "e3",
              "piece": "white_pawn"
            },
            {
              "type": "piece_on",
              "square": "d4",
              "piece": "black_pawn"
            },
            {
              "type": "piece_on",
              "square": "f4",
              "piece": "black_pawn"
            },
            {
              "type": "legal_move",
              "move": "e3d4"
            }
          ],
          "exports": {
            "png": "assets/diagrams/b01-c07-d03-pawn-diagonal-captures.png",
            "hash": "60da04ae846f57e730eb0d6b72536dc2eaf7ddf5186bf37e0bf21051e03ee224"
          }
        },
        {
          "id": "b01-c07-d04",
          "type": "board_diagram",
          "title": "Pawns do not capture forward",
          "fen": "4k3/8/8/8/4p3/4P3/8/4K3 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e3",
              "to": "e4",
              "colorRole": "wrong"
            }
          ],
          "highlights": [
            {
              "square": "e4",
              "colorRole": "wrong"
            }
          ],
          "caption_md": "The pawn on e3 cannot capture the enemy pawn directly in front of it on e4.",
          "assertions": [
            {
              "type": "piece_on",
