    {
      "id": "pawn-mistake",
      "title": "Common Mistake",
      "blocks": [
        {
          "id": "b01-c07-m01",
          "type": "mistake_refutation",
          "title": "Common mistake: moving backward",
          "fen": "4k3/8/8/8/4P3/8/8/4K3 w - - 0 1",
          "orientation": "white",
          "arrows": [
            {
              "from": "e4",
              "to": "e3",
              "colorRole": "wrong"
            }
          ],
          "highlights": [
            {
              "square": "e3",
              "colorRole": "wrong"
            }
          ],
          "body_md": "A white pawn on e4 cannot move backward to e3. Pawns only move forward unless they are promoting or capturing diagonally forward.",
          "caption_md": "Backward pawn moves are not legal.",
