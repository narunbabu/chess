  "chapterId": "06-knight-jumps",
  "title": "The Knight And Jumps",
  "subtitle": "The knight is the only piece that jumps over blockers.",
  "eloRange": "0-300",
  "requiredTier": "free",
  "estimatedMinutes": 24,
  "learningObjectives": [
    "Move a knight in an L shape.",
    "List the knight moves from a center square.",
    "Understand that knights jump over pieces but cannot land on friendly pieces.",
    "Recognize that edge knights have fewer moves."
  ],
  "sections": [
    {
      "id": "knight-shape",
      "title": "The L Shape",
      "blocks": [
        {
          "id": "b01-c06-p01",
          "type": "prose",
          "body_md": "The knight moves in an L shape: two squares in one direction and one square sideways. It is the only piece that can jump over pieces."
        },
        {
          "id": "b01-c06-d01",
