    "blocks": [
      {
        "id": "b01-c06-q01",
        "type": "quiz",
        "title": "What shape is a knight move?",
        "question_md": "A knight moves:",
        "options": [
          {
            "id": "a",
            "label": "In an L shape",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "Only diagonally",
            "isCorrect": false,
            "feedback": "That is a bishop."
          },
          {
            "id": "c",
            "label": "Only one square",
            "isCorrect": false,
            "feedback": "That is the king."
          }
        ]
      },
      {
        "id": "b01-c06-q02",
        "type": "quiz",
        "title": "Can knights jump?",
        "question_md": "A knight can jump over pieces:",
        "options": [
          {
            "id": "a",
            "label": "Yes",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "No",
            "isCorrect": false,
            "feedback": "The knight is the jumping piece."
          },
          {
            "id": "c",
            "label": "Only over pawns",
            "isCorrect": false,
            "feedback": "Knights can jump over any pieces."
          }
        ]
      },
      {
        "id": "b01-c06-q03",
        "type": "quiz",
        "title": "Where can the g1 knight move at the start?",
        "question_md": "From the starting position, the knight on g1 can move to:",
        "options": [
          {
            "id": "a",
            "label": "f3",
            "isCorrect": true,
            "feedback": "Correct."
          },
          {
            "id": "b",
            "label": "g3",
            "isCorrect": false,
            "feedback": "That is a straight move."
          },
          {
            "id": "c",
            "label": "g2",
            "isCorrect": false,
